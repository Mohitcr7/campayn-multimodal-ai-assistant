# .dockerignore — files excluded from the Docker build context
#
# Docker sends all files in the build context to the Docker daemon.
# Excluding large/sensitive files makes builds faster and images smaller.

# Python cache — never needed inside container
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.eggs/

# Data files — mounted as volumes at runtime, not baked into image
# If we baked the CSV here the image would be 500MB+
data/raw/
data/processed/
data/vector_store/
*.csv

# Logs — generated at runtime
logs/

# Git history — not needed in the image
.git/
.gitignore

# Dev files
.env             # NEVER bake .env into the image — it has secret keys
.env.*
!.env.example    # except the example (has no real keys)
notebooks/
*.ipynb
.ipynb_checkpoints/

# Tests — not needed in production container
tests/

# IDE
.vscode/
.idea/
*.swp
.DS_Store