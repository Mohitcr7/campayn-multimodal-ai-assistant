# Google Gemini — primary LLM (get free at aistudio.google.com)
GEMINI_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_VISION_MODEL=gemini-2.0-flash

# Fallback chain if Gemini fails: NVIDIA Nemotron (OpenRouter) → Anthropic Claude.
#
# 2nd choice — NVIDIA Nemotron 3 Ultra via OpenRouter (free tier).
# Get a key at openrouter.ai/keys. Leave blank to skip straight to Claude.
OPENROUTER_API_KEY=your-openrouter-key-here
OPENROUTER_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free

# 3rd choice — Anthropic Claude (last resort). Get a key at console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-key-here
ANTHROPIC_MODEL=claude-sonnet-5

# LangSmith observability (get free at smith.langchain.com)
LANGCHAIN_API_KEY=your-langsmith-key-here
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=campayn-ai-assistant

# ChromaDB vector store
CHROMA_PERSIST_DIR=data/vector_store
CHROMA_COLLECTION_NAME=campayn_knowledge_base
KNOWLEDGE_BASE_PATH=data/raw/knowledge_base.txt
MAX_RAG_CHUNKS=5

# Redis — conversation memory
REDIS_URL=redis://localhost:6379
CONVERSATION_TTL_SECONDS=3600

# API server
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development
